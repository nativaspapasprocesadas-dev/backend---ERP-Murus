# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    📋 PLANTILLA DE CONFIGURACIÓN                              ║
# ║                                                                              ║
# ║  Copia este archivo como .env y configura los valores según tu entorno       ║
# ║                                                                              ║
# ║  Para DESARROLLO LOCAL:                                                      ║
# ║  - Usa la base de datos PostgreSQL local (db_ERP_murus)                      ║
# ║  - NODE_ENV=development                                                       ║
# ║                                                                              ║
# ║  Para PRODUCCIÓN (Railway):                                                  ║
# ║  - Las variables se configuran en Railway Dashboard                           ║
# ║  - NODE_ENV=production                                                        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ============================================================================
# ENTORNO DE EJECUCIÓN
# ============================================================================
# Entorno: development | production
NODE_ENV=development

# ============================================================================
# SERVIDOR EXPRESS
# ============================================================================
# Puerto del servidor (en Railway se asigna automáticamente)
PORT=4020

# ============================================================================
# BASE DE DATOS POSTGRESQL
# ============================================================================
# 🏠 Para desarrollo local, usar PostgreSQL instalado en tu máquina
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_AQUI
DB_NAME=db_ERP_murus
DB_PORT=5432

# ============================================================================
# PRISMA ORM - URL DE CONEXIÓN
# ============================================================================
# Formato: postgresql://usuario:password@host:puerto/database?schema=public
DATABASE_URL="postgresql://postgres:TU_PASSWORD_AQUI@localhost:5432/db_ERP_murus?schema=public"

# ============================================================================
# SEGURIDAD JWT
# ============================================================================
# JWT Secret (usar uno robusto en producción)
JWT_SECRET=TU_SECRET_AQUI

# ============================================================================
# ZONA HORARIA
# ============================================================================
TZ=America/Lima

# ============================================================================
# WASABI S3 - Almacenamiento de objetos en la nube (Opcional)
# ============================================================================
WASABI_ACCESS_KEY=tu_access_key_aqui
WASABI_SECRET_KEY=tu_secret_key_aqui
WASABI_BUCKET=erp-papas-uploads
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com

# ============================================================================
# NOTAS PARA RAILWAY (Producción)
# ============================================================================
# - DATABASE_URL: Se configura automáticamente al vincular PostgreSQL
# - PORT: Railway asigna el puerto automáticamente
# - JWT_SECRET: Configurar manualmente en Dashboard con secret robusto
# - WASABI_*: Configurar manualmente en Dashboard si se usa almacenamiento S3
